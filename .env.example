# 复制为 .env 并填入真实值。.env 已被 .gitignore 忽略,不要提交。

# ---- Gemini Embedding(默认向量化提供方;未申请前可留空,不影响编译/搭骨架) ----
GEMINI_API_KEY=

# ---- PostgreSQL ----
PG_HOST=localhost
PG_PORT=5432
PG_DB=recsys
PG_USER=recsys
PG_PASSWORD=recsys

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- 可选:Kafka(docker compose --profile full 时) ----
KAFKA_SERVERS=localhost:9092
BEHAVIOR_USE_KAFKA=false

# ---- 策略开关 ----
RANK_STRATEGY=v1
EMBEDDING_PROVIDER=gemini

# ---- LLM query 理解(docs/04 §11;复用 GEMINI_API_KEY) ----
# 开启后用 Gemini 做拼写纠错/意图分类/query 改写;关闭或无 key 时 query 理解走纯词法兜底
LLM_ENABLED=false
LLM_MODEL=gemini-2.0-flash

# ---- 离线数据 ----
MOVIELENS_PATH=./data/ml-latest-small
