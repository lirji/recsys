# 密钥与本地环境
.env

# Maven
target/
*.jar
!.mvn/wrapper/maven-wrapper.jar

# 数据集与模型产物
data/
*.onnx

# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store

# 日志
*.log
logs/

# Python 虚拟环境
.venv/
__pycache__/
*.pyc

# 前端(console)依赖与构建产物;前后端分离后 console 独立构建,产物由 nginx 托管
node_modules/
console/node_modules/
console/dist/
console/.vite/
console/*.tsbuildinfo

# 训练数据与离线产物（由离线作业 / 训练脚本生成，可复现）
recsys-offline/train/*.csv
recsys-offline/eval/*.csv
# 本地 BGE 导出产物（体积大，可由 export_bge_onnx.py 复现；默认导到 ~/.recsys）
recsys-embedding/train/vocab.txt
recsys-embedding/train/*.json
recsys-embedding/train/tokenizer*
