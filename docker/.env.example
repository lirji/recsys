# docker compose 直接运行时的端口/凭据覆盖。复制为 docker/.env(gitignore),compose 会自动读取。
# 只影响「容器对宿主暴露的端口」;容器之间用服务名+标准内部端口通信,不受影响。
# 注:用 scripts/dev-local.sh 起时,它从 scripts/dev-local.env 读取覆盖并 export,不依赖本文件。

# 对宿主暴露端口(标准值;本机冲突时改这里)
GATEWAY_PORT=8080
CONSOLE_WEB_PORT=9095
PG_PORT=5432
REDIS_PORT=6379
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ALERTMANAGER_PORT=9093
KAFKA_PORT=9092
TRACING_SAMPLE=0.0

# none=纯词法降级；配置好 API key/本地模型后改为 gemini/local。
EMBEDDING_PROVIDER=none

# 数据库 / 凭据(容器 postgres 初始化 + ShardingSphere)
PG_DB=recsys
PG_DS1_DB=recsys_ds1
PG_USER=recsys
PG_PASSWORD=recsys

# 本地免登录直连(生产置 true 并注入密钥)
RECSYS_SECURITY_ENABLED=false

# Docker Console 默认展示 Casdoor 租户登录；回滚演示登录时须成对改为 legacy / false。
CONSOLE_AUTH_MODE=oidc
RECSYS_EDGE_CASDOOR=true
