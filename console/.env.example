# 认证模式(构建期烘焙,改后需重启 dev / 重新 build):
#   legacy(默认) = 演示登录(网关 RECSYS_EDGE_CASDOOR=false)
#   oidc         = Casdoor 统一登录(网关须同步 RECSYS_EDGE_CASDOOR=true,前后端开关成对!)
# 复制为 .env.local 按需修改;dev 用户 radmin/Radmin@12345(平台管理员)、rowner1/Rowner1@12345(广告主)。
VITE_AUTH_MODE=legacy

# 仅 oidc 模式生效。client_id = Casdoor shared app 的 -org-recsys 派生 id(与网关 casdoor.audiences 的 base 对应)。
VITE_CASDOOR_ISSUER=http://localhost:8000
VITE_CASDOOR_CLIENT_ID=ragshared0client00000001-org-recsys
VITE_CASDOOR_SCOPE=openid profile offline_access
