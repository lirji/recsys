# 本机端口/连接覆盖(可选)。复制为 scripts/dev-local.env(已 gitignore),按需改。
# 脚本 scripts/dev-local.sh 启动时会自动 source 本文件,覆盖“标准端口”默认值。
#
# 何时需要:本机默认端口(8080-8090 / pg 5432 / redis 6379)被其它项目占用时。
# 本仓库开发机即属此情况(8080-8090 被 langchain4j / apollo 占;pg 在 5455、redis 在 6380)。

# ---- 基础设施(已有持久容器)----
PG_HOST=127.0.0.1
PG_PORT=5455              # recsys-pg 容器映射端口(标准 5432 被占)
PG_DB=recsys
PG_DS1_DB=recsys_ds1      # 广告分库(ShardingSphere ds_1)
PG_USER=recsys
PG_PASSWORD=recsys
REDIS_HOST=127.0.0.1
REDIS_PORT=6380           # recsys-redis 容器映射端口(标准 6379 被占)

# ---- app 端口(8080-8090 被占 → 重映射到 90xx)----
GATEWAY_PORT=9080         # 前端入口(Vite /api 反代到这里)
REC_ENGINE_PORT=9081
BEHAVIOR_PORT=9082
ADVERTISER_PORT=9083
AD_SERVING_PORT=9085
CONTENT_PORT=9086
USER_PORT=9087
CONSOLE_PORT=9090
AD_SERVING_GRPC_PORT=9095
CONTENT_GRPC_PORT=9096
USER_GRPC_PORT=9097

# ---- 观测 ----
# 本机 Prometheus 挪到 19090(让开 console 的 9090);系统总览的 P99/QPS 从这里查。
PROMETHEUS_URL=http://localhost:19090

# 容器名(ensure_infra 用 docker start 兜底)
PG_CONTAINER=recsys-pg
REDIS_CONTAINER=recsys-redis
