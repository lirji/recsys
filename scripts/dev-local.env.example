# 本机端口覆盖(可选)。复制为 scripts/dev-local.env(已 gitignore),按需改。
# scripts/dev-local.sh 启动时会 source 本文件,并把这些变量 export 给 docker compose 的 ${VAR:-默认} 插值。
#
# 何时需要:本机默认端口(网关 8080 / pg 5432 / redis 6379 / nacos 8848)被其它项目占用时。
# 本仓库开发机即属此情况(8080-8090 被 langchain4j/apollo 占;5432/5455 被 pg 占、6379/6380 被 redis 占)。
#
# 重要:这些**只是容器对宿主暴露的端口**。容器之间固定用「服务名 + 标准内部端口」通信
#       (postgres:5432 / redis:6379 / nacos:8848 / gateway:8080),不受这里的重映射影响。
#       全链路容器化下,后端 app 根本不需要从宿主访问 pg/redis;这些端口主要给离线作业 / psql / 前端用。

# ---- 网关(前端入口;Vite /api 反代到这里)----
GATEWAY_PORT=8080

# ---- 前端 nginx 容器 ----
CONSOLE_WEB_PORT=9095

# ---- 基础设施对宿主暴露端口(容器内部仍是 5432/6379/8848)----
PG_PORT=5432
REDIS_PORT=6379
NACOS_PORT=8848
NACOS_GRPC_PORT=9848

# ---- 数据库 / 凭据(容器 postgres 初始化 + ShardingSphere)----
PG_DB=recsys
PG_DS1_DB=recsys_ds1
PG_USER=recsys
PG_PASSWORD=recsys

# ---- 本地免登录直连(生产置 true 并注入密钥)----
RECSYS_SECURITY_ENABLED=false

# ---- 观测栈(scripts/dev-local.sh obs)----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ---- 细粒度判权(可选,docs/09;scripts/dev-local.sh authz 起 SpiceDB)----
# 三态:disabled(默认,零行为变化)/ shadow(只记 would-deny)/ enforce(真拦 403)。
# 判权服务 auth-platform-server(:8210)在宿主机另起,advertiser 容器经 host.docker.internal 访问。
# RECSYS_AUTHZ_MODE=shadow
# AUTHZ_SERVER_URL=http://host.docker.internal:8210
# AUTHZ_CLIENT_TOKEN=
# RECSYS_SPICEDB_HTTP_PORT=8544
# RECSYS_SPICEDB_GRPC_PORT=50052

# ---- 统一登录 Casdoor OIDC(可选,docs/09;默认 legacy=自签 HS256 演示登录)----
# 成对开关:前端构建期 CONSOLE_AUTH_MODE=oidc + 网关 RECSYS_EDGE_CASDOOR=true;issuer 须浏览器可达。
# CONSOLE_AUTH_MODE=oidc
# RECSYS_EDGE_CASDOOR=true
# CASDOOR_ISSUER=http://localhost:8000
# CASDOOR_JWKS=http://host.docker.internal:8000/.well-known/jwks
# CASDOOR_AUDIENCES=ragshared0client00000001
# CASDOOR_CONSOLE_CLIENT_ID=ragshared0client00000001-org-recsys
# CASDOOR_ORG=recsys

# ---------------------------------------------------------------------------
# 本开发机(端口冲突)推荐覆盖 —— 直接取消注释即可:
# GATEWAY_PORT=9080
# CONSOLE_WEB_PORT=9195
# PG_PORT=5456
# REDIS_PORT=6381
# NACOS_PORT=8858
# NACOS_GRPC_PORT=9858
# PROMETHEUS_PORT=19091
# GRAFANA_PORT=3001
